{
  "name": "Three Node Network",
  "description": "A simple three node network to convert to ciw",
  "activities": [
    {
      "name": "Node 1",
      "type": "activity",
      "resource": {
        "name": "Resource 1",
        "capacity": 18
      },
      "service_distribution": {
        "type": "lognormal",
        "parameters": {
          "mean": 1,
          "std": 0.1
        }
      },
      "arrival_distribution": {
        "type": "exponential",
        "parameters": {
          "rate": 1.0
        }
      }
    },
    {
      "name": "Node 2",
      "type": "activity",
      "resource": {
        "name": "Resource 2",
        "capacity": 12
      },
      "service_distribution": {
        "type": "normal",
        "parameters": {
          "mean": 1,
          "std": 0.1
        }
      },
      "arrival_distribution": {
        "type": "exponential",
        "parameters": {
          "rate": 4.0
        }
      }
    },
    {
      "name": "Node 3",
      "type": "activity",
      "resource": {
        "name": "Resource 3",
        "capacity": 25
      },
      "service_distribution": {
        "type": "lognormal",
        "parameters": {
          "mean": 1,
          "std": 0.1
        }
      },
      "arrival_distribution": {
        "type": "exponential",
        "parameters": {
          "rate": 3.0
        }
      }
    }
  ],
  "transitions": [
    {
      "from": "Node 1",
      "to": "Exit",
      "probability": 0.1
    },
    {
      "from": "Node 1",
      "to": "Node 2",
      "probability": 0.6
    },
    {
      "from": "Node 1",
      "to": "Node 3",
      "probability": 0.3
    },
    {
      "from": "Node 2",
      "to": "Exit",
      "probability": 0.6
    },
    {
      "from": "Node 2",
      "to": "Node 1",
      "probability": 0.1
    },
    {
      "from": "Node 2",
      "to": "Node 3",
      "probability": 0.3
    },
    {
      "from": "Node 3",
      "to": "Exit",
      "probability": 0.2
    },
    {
      "from": "Node 3",
      "to": "Node 2",
      "probability": 0.4
    },
    {
      "from": "Node 3",
      "to": "Node 1",
      "probability": 0.4
    }
  ]
}